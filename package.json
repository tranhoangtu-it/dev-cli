{
  "name": "dev-cli",
  "version": "0.1.0",
  "description": "Developer productivity CLI tool built with Node.js",
  "type": "module",
  "bin": {
    "dev": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.js"
  },
  "keywords": [
    "cli",
    "developer",
    "productivity",
    "nodejs"
  ],
  "author": "tranhoangtu-it",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "jest": "^29.7.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "vitest": {
    "coverage": {
      "provider": "v8",
      "reporter": ["text", "json", "html"],
      "thresholds": {
        "lines": 90,
        "functions": 90,
        "branches": 90,
        "statements": 90
      },
      "exclude": ["node_modules/", "tests/"]
    }
  }
}
